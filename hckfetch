#!/usr/bin/env bash
# =============================================================================
# hckfetch — neofetch-style pentesting activity tracker
# =============================================================================
#
# USAGE EXAMPLES:
#   hckfetch              — display the full dashboard
#   hckfetch --no-logo    — skip the ASCII apple-pie art (great for small ttys)
#   hckfetch --reset      — wipe all usage logs and start fresh
#   hckfetch --help       — show this help text
#
# CUSTOMISATION:
#   • Edit TOOLS array to add/remove tracked tools.
#   • Edit TOOL_ICONS map to assign different nerd-font / unicode icons.
#   • Set HCKFETCH_SILENT=1 in your environment to suppress auto-display on
#     terminal open (the install script adds the auto-launch to your rc file).
#
# HOW IT WORKS:
#   hckfetch-wrap logs start/end epoch timestamps for each tool invocation
#   under ~/.hckfetch_logs/<tool>/  (one file per session).
#   hckfetch reads those files, sums the durations, and renders the dashboard.
#
# =============================================================================
#   Version : 1.0.0
#   Requires: bash 4+, date, awk, uname, lsb_release (optional)
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Version
# ---------------------------------------------------------------------------
HCKFETCH_VERSION="1.0.0"

# ---------------------------------------------------------------------------
# Colour palette (ANSI)
# ---------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Log directory
# ---------------------------------------------------------------------------
LOG_DIR="${HOME}/.hckfetch_logs"

# ---------------------------------------------------------------------------
# Tracked tools — add or remove entries freely
# ---------------------------------------------------------------------------
TOOLS=(
    nmap
    metasploit
    burpsuite
    sqlmap
    hydra
    john
    aircrack-ng
    gobuster
    nikto
    wireshark
    hashcat
    wfuzz
    ffuf
    crackmapexec
    enum4linux
)

# ---------------------------------------------------------------------------
# Tool icons (unicode / nerd-font glyphs with ASCII fallbacks)
# ---------------------------------------------------------------------------
declare -A TOOL_ICONS
TOOL_ICONS=(
    [nmap]="🔍"
    [metasploit]="💀"
    [burpsuite]="🕷️"
    [sqlmap]="🗄️"
    [hydra]="🐉"
    [john]="🔑"
    [aircrack-ng]="📡"
    [gobuster]="🚀"
    [nikto]="🕵️"
    [wireshark]="🦈"
    [hashcat]="🔓"
    [wfuzz]="🌊"
    [ffuf]="⚡"
    [crackmapexec]="🗺️"
    [enum4linux]="🐧"
)

# ---------------------------------------------------------------------------
# Apple-pie ASCII art logo
# ---------------------------------------------------------------------------
print_logo() {
    echo -e "${YELLOW}${BOLD}"
    cat << 'LOGO'
        .-"""""""""""-.
       /  Apple  Pie   \
      /   ___________   \
     |  /             \  |
     | |  ~~~~~~~~~~~  | |
     | |  ~  H A C K ~ | |
     | |  ~~~~~~~~~~~  | |
     |  \___________/  |
      \    [_______]   /
       \    |     |   /
        '-._|_____|_.-'
         |  |  |  |
         |__|  |__|
LOGO
    echo -e "${RESET}"
}

# ---------------------------------------------------------------------------
# Helper: format seconds → "Xh Ym" or "Ym Zs"
# ---------------------------------------------------------------------------
format_duration() {
    local secs="${1:-0}"
    local h=$(( secs / 3600 ))
    local m=$(( (secs % 3600) / 60 ))
    if (( h > 0 )); then
        printf "%dh %02dm" "$h" "$m"
    else
        local s=$(( secs % 60 ))
        printf "%dm %02ds" "$m" "$s"
    fi
}

# ---------------------------------------------------------------------------
# Parse all log files for a given tool; return total_seconds and run_count
# Log file format (written by hckfetch-wrap):
#   START <epoch>
#   END   <epoch>
# ---------------------------------------------------------------------------
get_tool_stats() {
    local tool="$1"
    local tool_dir="${LOG_DIR}/${tool}"
    local total_secs=0
    local runs=0
    local last_ts=0

    if [[ ! -d "$tool_dir" ]]; then
        echo "0 0 0"
        return
    fi

    while IFS= read -r -d '' logfile; do
        local start_ts=0 end_ts=0
        while IFS= read -r line; do
            case "$line" in
                START\ *)  start_ts="${line#START }" ;;
                END\ *)    end_ts="${line#END }"
                           if [[ "$start_ts" -gt 0 && "$end_ts" -gt "$start_ts" ]] 2>/dev/null; then
                               total_secs=$(( total_secs + end_ts - start_ts ))
                               runs=$(( runs + 1 ))
                               [[ "$end_ts" -gt "$last_ts" ]] && last_ts="$end_ts"
                           fi
                           start_ts=0; end_ts=0
                           ;;
            esac
        done < "$logfile"
    done < <(find "$tool_dir" -maxdepth 1 -name "*.log" -print0 2>/dev/null)

    echo "$total_secs $runs $last_ts"
}

# ---------------------------------------------------------------------------
# Format a unix timestamp as human-readable date, or "never"
# ---------------------------------------------------------------------------
format_timestamp() {
    local ts="${1:-0}"
    if (( ts == 0 )); then
        echo "never"
    else
        date -d "@${ts}" "+%Y-%m-%d %H:%M" 2>/dev/null \
            || date -r "$ts"  "+%Y-%m-%d %H:%M" 2>/dev/null \
            || echo "unknown"
    fi
}

# ---------------------------------------------------------------------------
# Gather system info
# ---------------------------------------------------------------------------
get_system_info() {
    SYS_OS="Unknown"
    SYS_KERNEL="$(uname -r 2>/dev/null || echo 'unknown')"
    SYS_ARCH="$(uname -m 2>/dev/null || echo 'unknown')"
    SYS_HOST="$(hostname 2>/dev/null || echo 'unknown')"
    SYS_USER="${USER:-$(id -un 2>/dev/null || echo 'hacker')}"
    SYS_UPTIME="unknown"
    SYS_SHELL="${SHELL:-unknown}"

    # Distro
    if command -v lsb_release &>/dev/null; then
        SYS_OS="$(lsb_release -sd 2>/dev/null | tr -d '"')"
    elif [[ -f /etc/os-release ]]; then
        SYS_OS="$(. /etc/os-release; echo "${PRETTY_NAME:-$NAME}")"
    elif [[ -f /etc/issue ]]; then
        SYS_OS="$(head -1 /etc/issue | sed 's/\\[^ ]*//g' | xargs)"
    fi

    # Uptime
    if [[ -f /proc/uptime ]]; then
        local up_secs
        up_secs="$(cut -d. -f1 /proc/uptime)"
        SYS_UPTIME="$(format_duration "$up_secs")"
    fi
}

# ---------------------------------------------------------------------------
# Print the right-hand stats panel
# ---------------------------------------------------------------------------
print_stats() {
    local show_logo="${1:-1}"  # 1 = show logo, 0 = hide

    get_system_info

    # ---- header bar ----
    echo -e "${GREEN}${BOLD}╔══════════════════════════════════════════════════╗${RESET}"
    printf "${GREEN}${BOLD}║${RESET}  ${CYAN}${BOLD}%-48s${RESET}${GREEN}${BOLD}║${RESET}\n" \
        "hckfetch v${HCKFETCH_VERSION} — pentest activity tracker"
    echo -e "${GREEN}${BOLD}╚══════════════════════════════════════════════════╝${RESET}"
    echo

    # ---- system info ----
    echo -e " ${BOLD}${MAGENTA}System Info${RESET}"
    echo -e " ${DIM}──────────────────────────────${RESET}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "User:"    "${SYS_USER}@${SYS_HOST}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "OS:"      "${SYS_OS}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "Kernel:"  "${SYS_KERNEL}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "Arch:"    "${SYS_ARCH}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "Uptime:"  "${SYS_UPTIME}"
    printf " ${CYAN}%-10s${RESET} %s\n"  "Shell:"   "${SYS_SHELL}"
    echo

    # ---- tool stats header ----
    echo -e " ${BOLD}${RED}Tool Usage Statistics${RESET}"
    echo -e " ${DIM}──────────────────────────────────────────────────${RESET}"
    printf " ${BOLD}${YELLOW}%-3s  %-16s  %-10s  %-6s  %-17s${RESET}\n" \
        "" "Tool" "Time" "Runs" "Last Session"
    echo -e " ${DIM}──────────────────────────────────────────────────${RESET}"

    local grand_total_secs=0
    local grand_total_runs=0
    local overall_last_ts=0

    for tool in "${TOOLS[@]}"; do
        local stats
        stats="$(get_tool_stats "$tool")"
        local total_secs runs last_ts
        read -r total_secs runs last_ts <<< "$stats"

        grand_total_secs=$(( grand_total_secs + total_secs ))
        grand_total_runs=$(( grand_total_runs + runs ))
        [[ "$last_ts" -gt "$overall_last_ts" ]] && overall_last_ts="$last_ts"

        local icon="${TOOL_ICONS[$tool]:-🔧}"
        local time_str
        time_str="$(format_duration "$total_secs")"
        local last_str
        last_str="$(format_timestamp "$last_ts")"

        # Colour by activity level
        local time_colour="${DIM}"
        if [[ "$total_secs" -ge 3600 ]]; then
            time_colour="${GREEN}${BOLD}"
        elif [[ "$total_secs" -ge 600 ]]; then
            time_colour="${YELLOW}"
        elif [[ "$total_secs" -gt 0 ]]; then
            time_colour="${CYAN}"
        fi

        printf " %s  ${BOLD}%-16s${RESET}  ${time_colour}%-10s${RESET}  %-6s  ${DIM}%-17s${RESET}\n" \
            "$icon" "$tool" "$time_str" "${runs}" "$last_str"
    done

    echo -e " ${DIM}──────────────────────────────────────────────────${RESET}"

    # totals row
    printf " ${BOLD}${MAGENTA}%-3s  %-16s  %-10s  %-6s  %-17s${RESET}\n" \
        "Σ" "TOTAL" "$(format_duration "$grand_total_secs")" \
        "${grand_total_runs}" "$(format_timestamp "$overall_last_ts")"

    echo
    echo -e " ${DIM}Tip: run ${BOLD}hckfetch --reset${DIM} to clear all logs.${RESET}"
    echo
}

# ---------------------------------------------------------------------------
# Reset — wipe all logs
# ---------------------------------------------------------------------------
do_reset() {
    read -rp $'\n'"${RED}${BOLD}WARNING:${RESET} This will delete ALL usage logs in ${LOG_DIR}.\nAre you sure? [y/N] " yn
    case "$yn" in
        [yY]|[yY][eE][sS])
            rm -rf "${LOG_DIR:?}"
            mkdir -p "$LOG_DIR"
            echo -e "${GREEN}✓ Logs cleared.${RESET}"
            ;;
        *)
            echo "Aborted."
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
print_help() {
    cat << EOF

${BOLD}hckfetch${RESET} v${HCKFETCH_VERSION} — neofetch-style pentesting activity tracker

${BOLD}USAGE:${RESET}
  hckfetch              Display the full dashboard
  hckfetch --no-logo    Hide the apple-pie ASCII logo
  hckfetch --reset      Wipe all usage logs
  hckfetch --help       Show this help

${BOLD}ENVIRONMENT:${RESET}
  HCKFETCH_SILENT=1     Suppress auto-display on terminal open

${BOLD}LOG DIRECTORY:${RESET}
  ${LOG_DIR}/

${BOLD}TOOL TRACKING:${RESET}
  Install hckfetch-wrap and add aliases via ./install.sh.
  Each alias invocation is logged as a session (start + end timestamp).

EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local show_logo=1

    for arg in "$@"; do
        case "$arg" in
            --no-logo)   show_logo=0 ;;
            --reset)     do_reset; exit 0 ;;
            --help|-h)   print_help; exit 0 ;;
            *)
                echo -e "${RED}Unknown option: ${arg}${RESET}"
                print_help
                exit 1
                ;;
        esac
    done

    # Honour HCKFETCH_SILENT
    if [[ "${HCKFETCH_SILENT:-0}" == "1" ]]; then
        exit 0
    fi

    echo
    if (( show_logo )); then
        print_logo
    fi

    print_stats "$show_logo"
}

main "$@"
